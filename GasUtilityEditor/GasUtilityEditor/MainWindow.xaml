<Window x:Class="GasUtilityEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
        xmlns:calcite="http://schemas.esri.com/calcite/2024"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border  Background="{DynamicResource CalciteBrandBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           Margin="10"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="ArcGIS Maps SDKs - Gas Utility Editor"
                           TextOptions.TextRenderingMode="Aliased" />
                <ProgressBar x:Name="IsBusy"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="10"
                             Grid.Column="1" />
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <esri:MapView x:Name="MyMapView" />

            <GroupBox HorizontalAlignment="Right"
                      Width="500">
                <GroupBox.Header>
                    <StackPanel>
                        <Button Click="OnChangeViewpoint"
                                Style="{StaticResource CalcitePrimaryButtonStyle}">
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{calcite:CalciteIconImage Icon=Extent, Brush=White}" />
                                    <TextBlock Text="Zoom To Area of Interest"
                                               Margin="5"
                                               Grid.Column="1" />
                                </Grid>
                            </Button.Content>
                        </Button>
                        <TextBlock Text="Template Picker"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="5" />
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border BorderThickness="1"
                            BorderBrush="LightGray">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE71E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="4"
                                       FontSize="14"
                                       Foreground="Gray"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="SearchText"
                                     IsEnabled="False"
                                     Margin="2"
                                     BorderThickness="0"
                                     Grid.Column="1"
                                     TextChanged="OnSearchTextChanged" />
                            <TextBlock Text="Filter by template name"
                                       VerticalAlignment="Center"
                                       Foreground="LightGray"
                                       Margin="2"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ElementName=SearchText, Path=Text, Converter={StaticResource VisibilityConverter}, ConverterParameter=Reverse}"
                                       Grid.Column="1" />
                            <TextBlock Text="&#xE8BB;"
                                       ToolTip="Clear Search"
                                       MouseLeftButtonUp="OnClearSearch"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="Gray"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Margin="4"
                                       Grid.Column="2"
                                       Visibility="{Binding ElementName=SearchText, Path=Text, Converter={StaticResource VisibilityConverter}}" />
                        </Grid>
                    </Border>
                    <ItemsControl x:Name="ToolPicker"
                                  Grid.Row="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button  Click="OnToolClicked"
                                         ToolTip="{Binding ToolType}"
                                         Margin="1">
                                    <Image Source="{Binding ImageSource}"
                                           Height="25"
                                           Width="25" />
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDefault}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource CalciteBrandBrush}" />
                                                    <Setter Property="BorderBrush"
                                                            Value="{StaticResource CalciteBrandBrush}" />
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource CalciteTextOnBrandBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEnabled}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ListView x:Name="TemplatePicker"
                              Grid.Row="2"
                              ItemTemplate="{StaticResource SymbolTemplate}"
                              ItemContainerStyle="{StaticResource AlternatingRowStyle}"
                              AlternationCount="2"
                              SelectionChanged="OnTemplateSelectionChanged">
                        <ListView.GroupStyle>
                            <GroupStyle ContainerStyle="{StaticResource ExpandableGroupStyle}" />
                        </ListView.GroupStyle>
                    </ListView>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>