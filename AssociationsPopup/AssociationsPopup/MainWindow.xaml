<Window x:Class="AssociationsPopup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:esri="http://schemas.esri.com/arcgis/runtime/2013"
        xmlns:calcite="http://schemas.esri.com/calcite/2024"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border  Background="{DynamicResource CalciteBrandBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="20"
                           Margin="10"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="ArcGIS Maps SDKs - Naperville Electric"
                           TextOptions.TextRenderingMode="Aliased" />
                <ProgressBar x:Name="IsBusy"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="10"
                             Grid.Column="1" />
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <esri:MapView x:Name="MyMapView"
                          ViewpointChanged="OnViewpointChanged"
                          GeoViewTapped="OnGeoViewTapped" />

            <!-- For displaying feature popup -->

            <Border  BorderBrush="Black"
                     BorderThickness="1"
                     Background="White"
                     Height="450"
                     Width="450"
                     Margin="10"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Visibility="Collapsed"
                     x:Name="PopupBorder">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Click="OnSelectCurrent"
                            HorizontalAlignment="Right">
                        <Button.Content>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Source="{calcite:CalciteIconImage Icon=ZoomToObject, Brush=Black}"
                                       Height="20"
                                       Width="20"
                                       Margin="2" />
                                <TextBlock Text="Select"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Margin="2"
                                           Grid.Column="1" />
                            </Grid>
                        </Button.Content>
                    </Button>
                    <esri:PopupViewer x:Name="MyPopupViewer"
                                      Margin="5" />
                </Grid>
            </Border>

            <!-- For displaying association graphics -->

            <GroupBox VerticalAlignment="Top"
                      HorizontalAlignment="Right">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Click="OnAssociationsClick"
                            x:Name="ShowAssociationsButton"
                            Style="{StaticResource CalcitePrimaryButtonStyle}"
                            Margin="5">
                        <Button.Content>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Source="{calcite:CalciteIconImage Icon=ViewAssociations, Brush=White}"
                                       Height="35"
                                       Width="35"
                                       Margin="2" />
                                <TextBlock Text="Associations"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Margin="2"
                                           Grid.Column="1" />
                            </Grid>
                        </Button.Content>
                    </Button>
                    <ListView x:Name="AssociationLegend"
                              Visibility="Visible"
                              Margin="5"
                              Grid.Row="1"
                              IsHitTestVisible="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Width="25"
                                           Height="25"
                                           Source="{Binding Value}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Key}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>